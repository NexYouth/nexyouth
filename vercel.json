{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "excludeFiles": "static/**" }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/static/(.*\\.(mp4|webm|mov))",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/static/(.*\\.(jpg|jpeg|png|gif|svg|webp|ico))",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=2592000, immutable"
      }
    },
    {
      "src": "/static/(.*\\.(css|js|woff|woff2|ttf|eot))",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=2592000"
      }
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py",
      "headers": {
        "Cache-Control": "public, max-age=300, s-maxage=600"
      }
    }
  ]
}
